# --- Base Configuration ---
# Enables Flattening in the example setup
# Default: true
FLATTENING_ENABLED="true"


# Pass comma separated list of enabled open types (types of extension you would like to support)
# Default: "boolean,code,date,dateTime,decimal,integer,string,Coding,CodeableConcept,Address,Identifier,Reference,Quantity"
ENABLED_OPEN_TYPES="boolean,code,date,dateTime,decimal,integer,string,Coding,CodeableConcept,Address,Identifier,Reference,Quantity,uri"