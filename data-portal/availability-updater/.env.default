# ---------------------------------------------------------------------------
# dataportal-availability-updater — Default Environment Configuration
# ---------------------------------------------------------------------------


# ---------------------------------------------------------------------------
# Ontology configuration
# ---------------------------------------------------------------------------

# Repository URL of the FHIR ontology generator release artifacts
# Default from project documentation
ONTO_REPO="https://github.com/medizininformatik-initiative/fhir-ontology-generator/releases/download"

# Git tag/version of the ontology to use
ONTO_GIT_TAG="v3.9.6

# Directory inside the container where ontology files are stored
# (Usually should NOT be changed)
ONTOLOGY_DIR="/opt/availability-updater/elastic_ontology"

# Whether the ontology should be updated on startup (true/false)
UPDATE_ONTOLOGY="true"


# ---------------------------------------------------------------------------
# Availability report import configuration
# ---------------------------------------------------------------------------

# Master identifier used to select DocumentReferences
AVAILABILITY_MASTER_IDENT="fdpg-data-availability-report"

# Input directory inside container (leave default unless you mount volumes)
AVAILABILITY_INPUT_DIR="/opt/availability-updater/availability_input"

# Output directory inside container (leave default unless you mount volumes)
AVAILABILITY_OUTPUT_DIR="/opt/availability-updater/availability_output"

# Base URL of the FHIR server hosting availability reports
# Replace with your actual FHIR endpoint
AVAILABILITY_REPORT_SERVER_BASE_URL="http://fhir-sever:8080/fhir"


# ---------------------------------------------------------------------------
# Elasticsearch configuration
# ---------------------------------------------------------------------------

# Base URL of the Elasticsearch instance
ES_BASE_URL="http://dataportal-elastic:9200"

# Target index where ontology/availability data will be stored
ES_INDEX="ontology"


# ---------------------------------------------------------------------------
# Processing behaviour
# ---------------------------------------------------------------------------

# Minimum number of reports required before availability is imported
MIN_N_REPORTS="1"

# Application log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOGLEVEL="INFO"

# ---------------------------------------------------------------------------
# Auth configuration
# ---------------------------------------------------------------------------

USE_OAUTH2=true
OAUTH_TOKEN_URL="https://auth.localhost:444/realms/blaze/protocol/openid-connect/token"
OAUTH_CLIENT_ID="account"
OAUTH_CLIENT_SECRET="insecure"
OAUTH_SCOPE=
USE_BASIC_AUTH=false
BASIC_USERNAME= 
BASIC_PASSWORD=
